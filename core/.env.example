# Copy this file to .env and adjust for your environment.
#
# DATABASE_URL points at a Dolt sql-server speaking the MySQL 8.0 protocol.
# The example below assumes a local dolt sql-server bound to 127.0.0.1
# (loopback only). That binding is the actual security boundary —
# nothing outside the local kernel can reach 127.0.0.1.
#
# This is a local-development convention, not a deployable default. Any
# binding wider than 127.0.0.1 (a public interface, a VPN/mesh interface,
# 0.0.0.0) MUST require authentication. Set up users via CREATE USER /
# GRANT and configure DATABASE_URL with real credentials in that case.

DATABASE_URL=mysql://root@127.0.0.1:3306/dolt
