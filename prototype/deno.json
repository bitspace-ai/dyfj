        "GEMINI_API_KEY",
        "DOLT_HOST",
        "DOLT_PORT",
        "DOLT_USER",
        "DOLT_PASSWORD",
        "DOLT_DATABASE",
        "NODE_DEBUG_NATIVE",
        "NODE_DISABLE_COMPILE_CACHE",
        "NODE_COMPILE_CACHE_PORTABLE",
        "NODE_COMPILE_CACHE"
      ],
      "read": [
        ".."
      ],
      "net": [
        "127.0.0.1:3306",
        "127.0.0.1:18080",
        "localhost:18080",
        "127.0.0.1:11434",
        "localhost:11434",
        "api.anthropic.com:443",
        "api.openai.com:443",
        "generativelanguage.googleapis.com:443"
      ],
      "run": [
        "bd"
      ]
    },
    "workbench-http": {
      "env": [
        "USER",
