  "imports": {
    "$dax": "jsr:@david/dax@0.42.0",
    "mysql2/promise": "npm:mysql2@3.22.3/promise",
    "ulid": "npm:ulid@2.4.0"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
