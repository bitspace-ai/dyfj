{
  "tasks": {
    "check": "deno check --sloppy-imports src/http.ts src/workbench.ts mcp/server.ts src/cli.ts",
    "test": "deno task check && TMPDIR=.vitest-tmp deno run -P=test --env-file=.env npm:vitest@3.2.6 run --root . --pool=threads",
    "start": "deno run -P=workbench --env-file=.env --sloppy-imports src/workbench.ts",
    "workbench": "deno run -P=workbench --env-file=.env --sloppy-imports src/workbench.ts",
    "workbench-http": "deno run -P=workbench-http --env-file=.env --sloppy-imports src/http.ts",
    "cli": "deno run -P=cli --sloppy-imports src/cli.ts",
    "compile-cli": "deno compile --allow-env --allow-net=127.0.0.1:8787,localhost:8787 --sloppy-imports -o dist/dyfj src/cli.ts",
    "context-size-response": "deno run -P=local-model-diagnostic --env-file=.env --sloppy-imports examples/context-size-response.ts",
    "model-response-modes": "deno run -P=local-model-diagnostic --env-file=.env --sloppy-imports examples/model-response-modes.ts",
    "structured-output": "deno run -P=local-model-diagnostic --env-file=.env --sloppy-imports examples/structured-output.ts",
    "structured-output-streaming": "deno run -P=local-model-diagnostic --env-file=.env --sloppy-imports examples/structured-output-streaming.ts",
    "beads-tracer": "deno run -P=beads --sloppy-imports examples/beads-tracer.ts",
    "verify-workbench-events": "deno run -P=verify-workbench-events --env-file=.env --sloppy-imports examples/verify-workbench-events.ts",
    "smoke": "deno run examples/deno-smoke-test.ts"
  },
  "permissions": {
    "test": {
      "env": true,
      "read": [
        "..",
        "../.."
      ],
      "write": [
        "."
      ],
      "net": [
        "127.0.0.1:3306",
        "localhost"
      ],
      "run": [
        "node_modules/.deno/esbuild@0.27.7/node_modules/esbuild/bin/esbuild",
        "node_modules/.deno/@esbuild+darwin-arm64@0.27.7/node_modules/@esbuild/darwin-arm64/bin/esbuild"
      ],
      "ffi": [
        "node_modules"
      ],
      "sys": [
        "cpus",
        "systemMemoryInfo",
        "networkInterfaces",
        "uid"
      ]
    },
    "workbench": {
      "env": [
        "USER",
        "DYFJ_PRINCIPAL_ID",
        "DYFJ_WORKBENCH_MODEL",
        "DYFJ_WORKBENCH_HINT",
        "DYFJ_WORKBENCH_TIER",
        "DYFJ_WORKBENCH_CONTEXT_PROFILE",
        "DYFJ_WORKBENCH_CONTEXT_TOKENS",
        "DYFJ_BUDGET_SESSION_USD",
