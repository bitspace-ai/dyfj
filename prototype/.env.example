# Copy to .env and fill in your values

# Your identity — used as principal_id in all telemetry events
DYFJ_PRINCIPAL_ID=your_username

# Notion integration (for Notion → Dolt task sync)
NOTION_API_KEY=your_notion_integration_token
NOTION_TASKS_DATABASE_ID=your_tasks_database_id
NOTION_DYFJ_PROJECT_PAGE_ID=your_project_page_id
