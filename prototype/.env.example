# Copy to .env and fill in your values

# Your identity — used as principal_id in all telemetry events
DYFJ_PRINCIPAL_ID=your_username

# Optional Workbench routing defaults. CLI flags still override these.
# DYFJ_WORKBENCH_MODEL=gemma4:e2b
# DYFJ_WORKBENCH_HINT=reasoning
# DYFJ_WORKBENCH_TIER=0
# DYFJ_WORKBENCH_CONTEXT_PROFILE=repo-first
# DYFJ_WORKBENCH_CONTEXT_TOKENS=500

# Local Dolt sql-server connection
DOLT_HOST=127.0.0.1
DOLT_PORT=3306
DOLT_USER=root
DOLT_PASSWORD=
DOLT_DATABASE=dolt

# Optional budget limits for paid inference guardrails
DYFJ_BUDGET_SESSION_USD=1.00
DYFJ_BUDGET_PER_CALL_USD=0.10
DYFJ_BUDGET_TALLY=paid

# Hosted inference (explicit escalation). Hosted providers fail closed when
# their key is absent. Prefer projecting these at process start from your
# secret manager (e.g. `op run`) over putting values in this file.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=

# Remote access (optional). When DYFJ_WORKBENCH_HTTP_HOST includes a
# non-loopback interface, the server requires this bearer key on every
# non-loopback request and refuses to bind without it. Project it at
# process start from your secret manager; do not put a value here.
# DYFJ_WORKBENCH_HTTP_HOST=127.0.0.1
# DYFJ_WORKBENCH_ALLOWED_HOSTS=
# DYFJ_WORKBENCH_API_KEY=
